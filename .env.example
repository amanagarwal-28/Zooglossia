# Copy this file to .env and fill in real values. Never commit .env to git.

# ─── API Server ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# MongoDB connection string
MONGO_URI=mongodb://mongodb:27017/zooglossia

# Strong random secret — generate with: openssl rand -hex 64
JWT_SECRET=replace_with_a_strong_random_secret

# Comma-separated list of allowed CORS/WebSocket origins (production)
ALLOWED_ORIGINS=https://yourdomain.com

# URL of the AI inference service (internal Docker network)
AI_SERVICE_URL=http://ai-service:8000

# ─── AI Service ──────────────────────────────────────────────────────────────
# HuggingFace token for downloading NatureLM model weights
HF_TOKEN=hf_replace_with_your_token

# Set to 1 to run AI service without loading heavy models (for CI / dev)
DEMO_MODE=0

# ─── Encryption ──────────────────────────────────────────────────────────────
# AES key for any at-rest encryption — generate with: openssl rand -hex 32
AES_KEY=replace_with_a_strong_random_key

# ─── Optional external services ──────────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_key_here
PINECONE_ENV=us-east-1

# Sentry DSN for error tracking (api-server)
SENTRY_DSN_API=

# Sentry DSN for error tracking (ai-service)
SENTRY_DSN_AI=

# Redis URL (used for job queue in Step 2)
REDIS_URL=redis://redis:6379
